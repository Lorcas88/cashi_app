meta {
  name: Register
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
}

body:json {
  {
    "email": "carlos@example.com",
    "password": "123456"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000
}

docs {
  Lista todas las categorías.
  
  ## Respuesta
  - 200: array de categorías
}
