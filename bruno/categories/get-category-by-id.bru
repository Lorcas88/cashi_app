meta {
  name: Get Category By Id
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/categories/{{categoryId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

vars:pre-request {
  baseUrl: http://localhost:3000
  categoryId: 1
}

docs {
  Obtiene una categoría por ID.
  
  ## Respuesta
  - 200: categoría encontrada
  - 404: categoría no existe
}
