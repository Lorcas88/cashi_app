meta {
  name: Delete Category
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/categories/{{categoryId}}
  body: none
}

vars:pre-request {
  baseUrl: http://localhost:3000
  categoryId: 1
}

docs {
  Elimina una categoría.
  
  ## Respuesta
  - 200: mensaje de éxito
  - 404: categoría no existe
}
