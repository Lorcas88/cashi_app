generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Una categoría tiene muchas transacciones (one-to-many)
model Category {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  transactions Transaction[]
}

// Dos posibles valores para el campo type de Transacciones
enum TransactionType {
  income
  expense
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

// Una transaccion pertenece a una categoría y puede tener muchas etiquetas
model Transaction {
  id          Int             @id @default(autoincrement())
  amount      Int
  type        TransactionType
  description String?
  date        DateTime        @db.Date
  receiptUrl  String?
  latitude    Float?
  longitude   Float?
  category    Category        @relation(fields: [categoryId], references: [id])
  categoryId  Int // foreign key
  user        User            @relation(fields: [userId], references: [id])
  userId      Int
}
